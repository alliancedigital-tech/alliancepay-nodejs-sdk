{
    "name": "@alliance-bank/payment-sdk",
    "version": "1.0.0",
    "license": "MIT",
    "author": "Alliance Bank",
    "type": "module",
    "description": "Alliance Bank Payment HPP Integration SDK",
    "main": "./dist/client.cjs",
    "module": "./dist/client.js",
    "types": "./dist/client.d.ts",
    "exports": {
        ".": {
            "types": "./dist/client.d.ts",
            "import": "./dist/client.js",
            "require": "./dist/client.cjs"
        }
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alliancedigital-tech/alliancepay-nodejs-sdk.git"
    },
    "bugs": {
        "url": "https://github.com/alliancedigital-tech/alliancepay-nodejs-sdk/issues"
    },
    "homepage": "https://github.com/alliancedigital-tech/alliancepay-nodejs-sdk#readme",
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup src/client.ts --format cjs,esm --dts --clean",
        "dev": "ts-node-dev --respawn index.ts",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "prepare": "npm run build"
    },
    "dependencies": {
        "jose": "^6.2.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^22.19.15",
        "@vitest/coverage-v8": "^4.1.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vitest": "^4.1.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
